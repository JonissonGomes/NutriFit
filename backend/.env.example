# ============================================
# NuFit Backend - Variáveis de ambiente
# ============================================
# Copie para .env e preencha os valores. Nunca commite o arquivo .env.
# cp .env.example .env

# ============================================
# SERVIDOR
# ============================================
PORT=8080
ENV=development

# ============================================
# MONGODB
# ============================================
# URI de conexão (Atlas ou local)
# Ex.: mongodb+srv://user:pass@cluster.mongodb.net/db?retryWrites=true&w=majority
MONGODB_URI=
MONGODB_DB=NuFit

# ============================================
# JWT
# ============================================
# Chave secreta para tokens (produção: use mínimo 32 caracteres, ex.: openssl rand -base64 32)
JWT_SECRET=change-me-in-production
JWT_ACCESS_EXPIRY=1h
JWT_REFRESH_EXPIRY=168h

# ============================================
# CLOUDINARY (upload de imagens)
# ============================================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_BASE_FOLDER=nufit

# ============================================
# LIMITE DE ARMAZENAMENTO (bytes) - plano gratuito
# ============================================
# 5GB para novos usuários
STORAGE_LIMIT_FREE=5368709120

# ============================================
# CORS
# ============================================
# Origens permitidas separadas por vírgula
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================
# REDIS (opcional)
# ============================================
REDIS_URL=

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m

# ============================================
# GEOLOCALIZAÇÃO POR IP (opcional)
# ============================================
IP_GEOLOCATION_API_KEY=
IP_GEOLOCATION_PROVIDER=ipapi.co
IP_GEOLOCATION_CACHE_TTL=24h

# ============================================
# BOOST – PREÇOS (BRL)
# ============================================
BOOST_BASIC_DAILY_PRICE=9.90
BOOST_BASIC_WEEKLY_PRICE=49.90
BOOST_BASIC_MONTHLY_PRICE=149.90
BOOST_PREMIUM_DAILY_PRICE=19.90
BOOST_PREMIUM_WEEKLY_PRICE=99.90
BOOST_PREMIUM_MONTHLY_PRICE=299.90
BOOST_HIGHLIGHT_DAILY_PRICE=39.90
BOOST_HIGHLIGHT_WEEKLY_PRICE=199.90
BOOST_HIGHLIGHT_MONTHLY_PRICE=599.90

# ============================================
# IA (Gemini)
# ============================================
# Chave da API Google AI (Gemini) para recursos de IA
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Modelo global padrão (fallback) para texto/vision.
# Ex.: gemini-2.0-flash
GEMINI_MODEL=

# Modelo Gemini para geração de texto
# Ex.: gemini-1.5-pro
GEMINI_TEXT_MODEL=gemini-1.5-pro

# Modelo Gemini para análise de imagem (Vision)
# Ex.: gemini-1.5-flash
GEMINI_VISION_MODEL=gemini-1.5-flash

# ============================================
# Email (SMTP – boas-vindas no cadastro)
# ============================================
# Conta Gmail e senha de app (não use a senha normal da conta)
EMAIL_USER=
EMAIL_PASS=
# Nome exibido como remetente
GMAIL_FROM_NAME=NuFit
# URL da tela de login (usada no e-mail de boas-vindas). Ex.: http://localhost:5173/login
APP_LOGIN_URL=http://localhost:5173/login
GMAIL_SMTP_HOST=smtp.gmail.com
GMAIL_SMTP_PORT=587