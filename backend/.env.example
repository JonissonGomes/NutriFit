# ============================================
# SERVER CONFIGURATION
# ============================================
# Porta em que o servidor backend irá rodar
PORT=8080

# Ambiente: development, staging, production
ENV=development

# ============================================
# MONGODB ATLAS
# ============================================
# URI de conexão do MongoDB Atlas
# Onde buscar: MongoDB Atlas Dashboard > Clusters > Connect > Connect your application
# Formato: mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/arckdesign?retryWrites=true&w=majority

# Nome do banco de dados no MongoDB
MONGODB_DB=arckdesign

# ============================================
# JWT CONFIGURATION
# ============================================
# Chave secreta para assinar tokens JWT
# IMPORTANTE: Use uma chave forte e aleatória em produção (mínimo 32 caracteres)
# Gerar: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-here-change-in-production-min-32-chars

# Tempo de expiração do access token (1 hora)
JWT_ACCESS_EXPIRY=1h

# Tempo de expiração do refresh token (7 dias = 168 horas)
JWT_REFRESH_EXPIRY=168h

# ============================================
# OAUTH GOOGLE
# ============================================
# Client ID do Google OAuth
# Onde buscar: Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client IDs
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Client Secret do Google OAuth
# Onde buscar: Mesmo local do Client ID (mostrar secret)
GOOGLE_CLIENT_SECRET=your-google-client-secret

# URI de redirecionamento após autenticação Google
# Deve estar configurada no Google Cloud Console > Authorized redirect URIs
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/google/callback

# ============================================
# CLOUDINARY CONFIGURATION
# ============================================
# Nome da sua conta Cloudinary
# Onde buscar: Cloudinary Dashboard > Settings > Account Details
# https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloud-name

# API Key do Cloudinary
# Onde buscar: Cloudinary Dashboard > Settings > Security
CLOUDINARY_API_KEY=your-api-key

# API Secret do Cloudinary
# Onde buscar: Cloudinary Dashboard > Settings > Security (mostrar secret)
CLOUDINARY_API_SECRET=your-api-secret

# Pasta base onde as imagens serão armazenadas no Cloudinary
# Estrutura: arck-design/users/{userId}/projects/{projectId}/
CLOUDINARY_BASE_FOLDER=arck-design

# ============================================
# STORAGE LIMITS (em bytes)
# ============================================
# Limite de armazenamento para plano Free (5GB)
STORAGE_LIMIT_FREE=5368709120

# Limite de armazenamento para plano Starter (10GB)
STORAGE_LIMIT_STARTER=10737418240

# Limite de armazenamento para plano Professional (50GB)
STORAGE_LIMIT_PRO=53687091200

# Limite de armazenamento para plano Business (200GB)
STORAGE_LIMIT_BUSINESS=214748364800

# ============================================
# CORS CONFIGURATION
# ============================================
# Origens permitidas para requisições CORS (separadas por vírgula)
# Adicione os domínios do frontend em produção
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://arckdesign.com

# ============================================
# REDIS (Opcional)
# ============================================
# URL de conexão do Redis para cache e WebSocket
# Onde buscar: Redis Cloud ou instalação local
# Formato: redis://username:password@host:port
# Opcional: Deixe vazio se não usar Redis
REDIS_URL=redis://localhost:6379

# ============================================
# RATE LIMITING
# ============================================
# Número máximo de requisições permitidas por janela de tempo
RATE_LIMIT_REQUESTS=100

# Janela de tempo para rate limiting (1 minuto)
RATE_LIMIT_WINDOW=1m

# ============================================
# IP GEOLOCATION (Fallback)
# ============================================
# API Key para serviço de geolocalização por IP (fallback quando navegador não disponível)
# Onde buscar: https://ipapi.co/ ou https://ip-api.com/
# Opcional: Deixe vazio se não usar
IP_GEOLOCATION_API_KEY=your-api-key

# Provedor de geolocalização: ipapi.co, ip-api.com, maxmind
IP_GEOLOCATION_PROVIDER=ipapi.co

# Tempo de cache para geolocalização (24 horas)
IP_GEOLOCATION_CACHE_TTL=24h

# ============================================
# BOOST SYSTEM PRICING (em BRL)
# ============================================
# Preços do sistema de impulsionamento de perfis

# Plano Básico - Diário
BOOST_BASIC_DAILY_PRICE=9.90

# Plano Básico - Semanal
BOOST_BASIC_WEEKLY_PRICE=49.90

# Plano Básico - Mensal
BOOST_BASIC_MONTHLY_PRICE=149.90

# Plano Premium - Diário
BOOST_PREMIUM_DAILY_PRICE=19.90

# Plano Premium - Semanal
BOOST_PREMIUM_WEEKLY_PRICE=99.90

# Plano Premium - Mensal
BOOST_PREMIUM_MONTHLY_PRICE=299.90

# Plano Destaque - Diário
BOOST_HIGHLIGHT_DAILY_PRICE=39.90

# Plano Destaque - Semanal
BOOST_HIGHLIGHT_WEEKLY_PRICE=199.90

# Plano Destaque - Mensal
BOOST_HIGHLIGHT_MONTHLY_PRICE=599.90
