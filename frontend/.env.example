# ============================================
# API CONFIGURATION
# ============================================
# URL base da API backend
# Em desenvolvimento: http://localhost:8080
# Em produção: https://api.arckdesign.com
VITE_API_URL=http://localhost:8080

# URL base completa da API (incluindo /api/v1)
VITE_API_BASE_URL=http://localhost:8080/api/v1

# ============================================
# ENVIRONMENT
# ============================================
# Ambiente atual: development, staging, production
VITE_ENV=development

# ============================================
# OAUTH GOOGLE CONFIGURATION
# ============================================
# Client ID do Google OAuth (mesmo do backend)
# Onde buscar: Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client IDs
# https://console.cloud.google.com/apis/credentials
# IMPORTANTE: Use o mesmo Client ID do backend
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# URI de redirecionamento após autenticação Google
# Deve estar configurada no Google Cloud Console > Authorized redirect URIs
VITE_GOOGLE_REDIRECT_URI=http://localhost:5173/auth/google/callback

# ============================================
# CLOUDINARY CONFIGURATION (Opcional)
# ============================================
# Configuração para uploads diretos do frontend (se necessário)
# Onde buscar: Cloudinary Dashboard > Settings
# https://cloudinary.com/console

# Nome da conta Cloudinary
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name

# Upload Preset do Cloudinary (para uploads não autenticados)
# Onde buscar: Cloudinary Dashboard > Settings > Upload > Upload presets
# Criar um preset com: Signing mode: Unsigned
VITE_CLOUDINARY_UPLOAD_PRESET=your-upload-preset

# ============================================
# APP CONFIGURATION
# ============================================
# Nome da aplicação
VITE_APP_NAME=ArckDesign

# URL base da aplicação frontend
# Em desenvolvimento: http://localhost:5173
# Em produção: https://arckdesign.com
VITE_APP_URL=http://localhost:5173

# ============================================
# FEATURE FLAGS (Opcional)
# ============================================
# Ativar/desativar funcionalidades específicas
# true = ativado, false = desativado

# Visualizador 3D para modelos CAD
VITE_ENABLE_3D_VIEWER=true

# Sistema de geolocalização
VITE_ENABLE_GEOLOCATION=true

# Sistema de impulsionamento de perfis
VITE_ENABLE_BOOST=true

# ============================================
# ANALYTICS (Opcional)
# ============================================
# Google Analytics Tracking ID
# Onde buscar: Google Analytics > Admin > Property Settings > Tracking ID
# https://analytics.google.com/
# Deixe vazio se não usar
VITE_GOOGLE_ANALYTICS_ID=

# PostHog API Key (para analytics avançado)
# Onde buscar: PostHog Dashboard > Project Settings > Project API Key
# https://posthog.com/
# Deixe vazio se não usar
VITE_POSTHOG_KEY=

# ============================================
# ERROR TRACKING (Opcional)
# ============================================
# Sentry DSN para rastreamento de erros
# Onde buscar: Sentry Dashboard > Settings > Projects > Client Keys (DSN)
# https://sentry.io/
# Deixe vazio se não usar
VITE_SENTRY_DSN=
