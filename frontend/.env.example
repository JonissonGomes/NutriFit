# ============================================
# NuFit Frontend - Variáveis de ambiente
# ============================================
# Copie para .env e preencha os valores. Nunca commite o arquivo .env.
# cp .env.example .env
#
# Todas as variáveis expostas ao Vite precisam do prefixo VITE_

# ============================================
# API
# ============================================
# URL base da API (desenvolvimento)
# Produção: https://api.seudominio.com/api/v1
VITE_API_BASE_URL=http://localhost:8080/api/v1

# ============================================
# AMBIENTE
# ============================================
VITE_ENV=development

# ============================================
# APP
# ============================================
VITE_APP_NAME=NuFit
# URL do frontend
VITE_APP_URL=http://localhost:5173

# ============================================
# CLOUDINARY (opcional – uploads diretos do frontend)
# ============================================
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=

# ============================================
# FEATURES (opcional)
# ============================================
VITE_ENABLE_3D_VIEWER=true
VITE_ENABLE_GEOLOCATION=true
VITE_ENABLE_BOOST=true

# ============================================
# ANALYTICS / MONITORAMENTO (opcional)
# ============================================
# Deixe vazio se não usar
VITE_GOOGLE_ANALYTICS_ID=
VITE_POSTHOG_KEY=
VITE_SENTRY_DSN=
